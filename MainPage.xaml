<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp6.MainPage" Rotation="90">


    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>


            <Button
                Text="Go to the next page"
                Grid.Row="0" Grid.Column="0" HorizontalOptions="Start" Margin="30" Padding="30"
                Clicked="OnNextPageClicked"/>
            <Button
                Text="Sale Page"
                Grid.Row="1" Grid.Column="1" HorizontalOptions="Center" Margin="30" Padding="30"
                Clicked="OnSalePageClicked"/>
             <Button
                Text="Future Use"
                Grid.Row="2" Grid.Column="2" HorizontalOptions="End" Margin="30" Padding="30"
                Clicked="OnNextPageClicked"/>
